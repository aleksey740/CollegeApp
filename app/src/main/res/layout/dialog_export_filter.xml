<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Учащиеся"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:layout_marginBottom="6dp" />
    <RadioGroup
        android:id="@+id/studentScopeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <RadioButton
            android:id="@+id/radioAllStudents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Все учащиеся"
            android:checked="true" />
        <RadioButton
            android:id="@+id/radioSelectedStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выбранный учащийся" />
    </RadioGroup>
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/studentDropdownLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:hint="Учащийся">
        <AutoCompleteTextView
            android:id="@+id/studentDropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Предмет"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/subjectDropdownLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:hint="Выберите предмет">
        <AutoCompleteTextView
            android:id="@+id/subjectDropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Семестр"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/semesterDropdownLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:hint="Выберите семестр">
        <AutoCompleteTextView
            android:id="@+id/semesterDropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
