<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_stickers"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:letterSpacing="0.02"
        android:text="@string/stickers_sheet_title"
        android:textColor="#E2E8F0"
        android:textSize="15sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/stickerPickerRecycler"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        tools:listitem="@layout/item_sticker_picker_cell" />
</LinearLayout>
