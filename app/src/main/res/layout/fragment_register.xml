<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_gradient_purple"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Регистрация"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Создайте новый аккаунт"
            android:textSize="15sp"
            android:textColor="#94A3B8"
            android:layout_marginTop="6dp" />

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_auth_card"
            android:padding="24dp"
            android:layout_marginTop="28dp">

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ФИО"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/auth_input_stroke_purple"
                app:boxStrokeWidth="1dp"
                app:boxBackgroundColor="#0F172A"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/fullNameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textColor="#F1F5F9"
                    android:textColorHint="#64748B"
                    android:hint="Иванов Иван Иванович"
                    android:inputType="textPersonName"
                    android:paddingStart="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/auth_input_stroke_purple"
                app:boxStrokeWidth="1dp"
                app:boxBackgroundColor="#0F172A"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textColor="#F1F5F9"
                    android:textColorHint="#64748B"
                    android:hint="example@email.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пароль"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/auth_input_stroke_purple"
                app:boxStrokeWidth="1dp"
                app:boxBackgroundColor="#0F172A"
                app:hintEnabled="false"
                app:endIconMode="password_toggle"
                app:endIconTint="#64748B">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textColor="#F1F5F9"
                    android:textColorHint="#64748B"
                    android:hint="Минимум 6 символов"
                    android:inputType="textPassword"
                    android:paddingStart="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пол"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/genderInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/auth_input_stroke_purple"
                app:boxStrokeWidth="1dp"
                app:boxBackgroundColor="#0F172A"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/genderSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textColor="#F1F5F9"
                    android:inputType="none"
                    android:paddingStart="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Группа"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/groupInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/auth_input_stroke_purple"
                app:boxStrokeWidth="1dp"
                app:boxBackgroundColor="#0F172A"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/groupEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textColor="#F1F5F9"
                    android:textColorHint="#64748B"
                    android:hint="Например: ИТ-21"
                    android:inputType="text"
                    android:paddingStart="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Роль"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/auth_input_stroke_purple"
                app:boxStrokeWidth="1dp"
                app:boxBackgroundColor="#0F172A"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/roleSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textColor="#F1F5F9"
                    android:inputType="none"
                    android:paddingStart="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            
            <TextView
                android:id="@+id/privacyPolicyConsentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:lineSpacingMultiplier="1.3" />

            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/registerButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Создать аккаунт"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                app:backgroundTint="#8B5CF6"
                app:rippleColor="#6D28D9" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="#8B5CF6"
                android:visibility="gone" />

        </LinearLayout>

        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Уже есть аккаунт? "
                android:textSize="15sp"
                android:textColor="#64748B" />

            <TextView
                android:id="@+id/loginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Войти"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#A78BFA"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
