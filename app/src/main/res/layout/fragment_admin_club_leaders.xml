<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/clubLeadersHeaderLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_gradient"
            android:paddingHorizontal="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="22dp"
            android:clipToPadding="false"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/clubLeadersBackButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:background="@null"
                    android:foreground="@null"
                    android:padding="0dp"
                    android:scaleType="center"
                    android:tint="#FFFFFF"
                    app:srcCompat="@drawable/ic_chevron_left"
                    android:contentDescription="Назад"
                    android:visibility="visible" />

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="🎯"
                    android:textSize="26sp"
                    android:background="@drawable/bg_icon_purple" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:text="Руководители кружков, секций и факультативов"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="4"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="1.06"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="28dp">

                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_subtle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:gravity="center"
                                android:text="🎯"
                                android:textSize="20sp"
                                android:background="@drawable/bg_icon_purple" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Кружки"
                                    android:textColor="@color/text_primary_dark"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Руководители внеучебных кружков"
                                    android:textColor="@color/text_secondary_dark"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/badgeClubsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="28dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_catalog_badge"
                                android:text="0"
                                android:textColor="@color/accent_tertiary"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_catalog_divider" />

                        <LinearLayout
                            android:id="@+id/leadersListClubs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minHeight="36dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addLeaderClubsButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Добавить руководителя"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/accent_primary_dark"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_subtle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:gravity="center"
                                android:text="⚽"
                                android:textSize="22sp"
                                android:background="@drawable/bg_icon_green" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Секции"
                                    android:textColor="@color/text_primary_dark"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Спортивные и тематические секции"
                                    android:textColor="@color/text_secondary_dark"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/badgeSectionsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="28dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_catalog_badge"
                                android:text="0"
                                android:textColor="@color/accent_emerald"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_catalog_divider" />

                        <LinearLayout
                            android:id="@+id/leadersListSections"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minHeight="36dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addLeaderSectionsButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Добавить руководителя"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/accent_emerald"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_subtle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:gravity="center"
                                android:text="📖"
                                android:textSize="20sp"
                                android:background="@drawable/bg_icon_blue" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Факультативы"
                                    android:textColor="@color/text_primary_dark"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Дополнительные учебные курсы"
                                    android:textColor="@color/text_secondary_dark"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/badgeElectivesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="28dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_catalog_badge"
                                android:text="0"
                                android:textColor="@color/accent_secondary"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_catalog_divider" />

                        <LinearLayout
                            android:id="@+id/leadersListElectives"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minHeight="36dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addLeaderElectivesButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Добавить руководителя"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/accent_secondary"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/clubLeadersProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent_primary_dark"
        android:visibility="gone" />
</FrameLayout>
