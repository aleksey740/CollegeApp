<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1E293B"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        
        <View
            android:id="@+id/statusBar"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="#EF4444" />

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                
                <TextView
                    android:id="@+id/subjectText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Математика"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginEnd="8dp"
                    tools:text="Программирование на Python" />

                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_chip_dark"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱️"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/hoursText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 ч."
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#F87171"
                        android:layout_marginStart="4dp"
                        tools:text="4 ч." />

                </LinearLayout>

            </LinearLayout>

            
            <TextView
                android:id="@+id/studentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Иванов Иван Иванович"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="👤 Петров Пётр Петрович" />

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/reasonText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Без причины"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_type_badge"
                    tools:text="Болезнь" />

                
                <TextView
                    android:id="@+id/excusedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌ Н/У"
                    android:textSize="11sp"
                    android:textColor="#F87171"
                    android:layout_marginStart="8dp"
                    tools:text="✅ Уваж." />

            </LinearLayout>

            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#334155"
                android:layout_marginVertical="10dp" />

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_chip_dark"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/dateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18.12.2025"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#A78BFA"
                        android:layout_marginStart="4dp"
                        tools:text="25.12.2025" />

                </LinearLayout>

            </LinearLayout>

            
            <TextView
                android:id="@+id/commentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💬 Комментарий..."
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="💬 Не предоставил справку" />

            
            <TextView
                android:id="@+id/createdByText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✍️ Иванов И.И."
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="6dp"
                tools:text="✍️ Куратор: Иванов Иван Иванович" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
