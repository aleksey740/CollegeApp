<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_teacher_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/teacherJournalBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="10dp"
            android:background="@null"
            android:foreground="@null"
            android:padding="0dp"
            android:scaleType="center"
            android:tint="#FFFFFF"
            app:srcCompat="@drawable/ic_chevron_left"
            android:contentDescription="Назад" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Журнал отметок"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/groupText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Группа:"
                android:textColor="#CBD5E1"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportBtn"
            style="@style/Widget.Material3.Button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text=""
            android:contentDescription="Экспорт"
            app:cornerRadius="999dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconSize="20dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:backgroundTint="@android:color/transparent" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/journalPageScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Предмет"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:boxBackgroundColor="#0F172A"
                        app:boxStrokeColor="#334155"
                        app:endIconMode="dropdown_menu"
                        app:hintTextColor="#94A3B8">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/subjectDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Выберите предмет"
                            android:inputType="none"
                            android:focusable="false"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#94A3B8" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Семестр"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:boxBackgroundColor="#0F172A"
                        app:boxStrokeColor="#334155"
                        app:endIconMode="dropdown_menu"
                        app:hintTextColor="#94A3B8">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/semesterDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Выберите семестр"
                            android:inputType="none"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#94A3B8" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_week_navigation"
                        android:padding="6dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/prevWeekBtn"
                            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:icon="@drawable/ic_chevron_left"
                            app:iconSize="24dp"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:backgroundTint="#334155"
                            app:iconTint="#E2E8F0"
                            app:cornerRadius="12dp" />

                        <TextView
                            android:id="@+id/weekLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:textColor="#F1F5F9"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nextWeekBtn"
                            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:icon="@drawable/ic_chevron_right"
                            app:iconSize="24dp"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:backgroundTint="#334155"
                            app:iconTint="#E2E8F0"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/emptyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет данных для журнала"
                    android:textColor="#94A3B8"
                    android:textSize="15sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/journalScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fillViewport="false"
                android:scrollbars="horizontal"
                android:scrollbarStyle="outsideOverlay"
                android:overScrollMode="always"
                android:nestedScrollingEnabled="true"
                android:paddingHorizontal="12dp"
                android:visibility="gone">

                <TableLayout
                    android:id="@+id/tableLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
