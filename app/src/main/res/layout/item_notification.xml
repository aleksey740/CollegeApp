<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1E293B"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        
        <TextView
            android:id="@+id/typeIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="🔔"
            android:textSize="24sp"
            android:background="@drawable/bg_icon_blue" />

        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Заголовок уведомления"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/messageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Текст уведомления"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25.12.2025 14:30"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        
        <View
            android:id="@+id/unreadIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_notification_indicator"
            android:layout_marginEnd="4dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
