<resources xmlns:tools="http://schemas.android.com/tools">
    
    <style name="Base.Theme.CollegeApp" parent="Theme.Material3.Dark.NoActionBar">
        
        <item name="colorPrimary">#8B5CF6</item>
        <item name="colorPrimaryVariant">#6D28D9</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        
        
        <item name="colorSecondary">#818CF8</item>
        <item name="colorSecondaryVariant">#6366F1</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        
        
        <item name="colorTertiary">#22D3EE</item>
        <item name="colorOnTertiary">#0F172A</item>
        
        
        <item name="android:colorBackground">#020617</item>
        <item name="colorSurface">#1E293B</item>
        <item name="colorOnSurface">#F8FAFC</item>
        <item name="colorSurfaceVariant">#334155</item>
        <item name="colorOnSurfaceVariant">#94A3B8</item>
        
        
        <item name="colorError">#FB7185</item>
        <item name="colorOnError">#FFFFFF</item>
        
        
        <item name="colorOutline">#334155</item>
        <item name="colorOutlineVariant">#1E293B</item>
        
        
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
        
        
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
    </style>

    <style name="Theme.CollegeApp" parent="Base.Theme.CollegeApp" />
    
    
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_primary_dark</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    
    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    
    <style name="Widget.App.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent_primary</item>
    </style>

    
    <style name="ShapeAppearanceOverlay.Sticker.Chat" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>
    <style name="ShapeAppearanceOverlay.Sticker.Picker" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>
